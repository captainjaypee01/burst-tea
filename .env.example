# Copy to .env at repo root for Docker Compose variable substitution (optional).
# Backend copies from backend/.env — see BLUEPRINT.md.

# MySQL (docker-compose)
MYSQL_DATABASE=burst_tea
MYSQL_USER=burst
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret
# Host port published to your machine (container MySQL still listens on 3306).
MYSQL_PORT=3307

# Redis
REDIS_PORT=6379

# App URLs (dev)
APP_URL=http://localhost:8090
FRONTEND_URL=http://localhost:5173

# Laravel (set in backend/.env — examples)
# APP_KEY=
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=burst_tea
# DB_USERNAME=burst
# DB_PASSWORD=secret
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
# SESSION_DOMAIN=localhost

# Frontend (Vite) — copy frontend/.env.example to frontend/.env for local npm run dev
# VITE_API_URL=http://localhost:8090/api/v1
